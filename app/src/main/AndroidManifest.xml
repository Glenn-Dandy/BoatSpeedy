<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Präziser Standort für GPS-Geschwindigkeit & Satellitenstatus. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Vordergrunddienst: misst während einer Fahrt weiter (Screen aus /
         App im Hintergrund). Keine ACCESS_BACKGROUND_LOCATION nötig, da der
         Dienst aus der geöffneten App gestartet wird. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.BoatSpeedy">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.BoatSpeedy">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".trip.LocationService"
            android:exported="false"
            android:foregroundServiceType="location" />
    </application>

</manifest>
